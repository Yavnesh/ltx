# Service settings
ENVIRONMENT=local
PROJECT_NAME="LTX Video Platform"
API_PORT=8000
JWT_SECRET=generate-a-secure-secret-key-for-prod
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ltx_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_PROVIDER_TYPE=local
STORAGE_LOCAL_PATH=/tmp/ltx_storage
STORAGE_ENDPOINT_URL=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET_NAME=ltx-videos
STORAGE_REGION=us-east-1

# Video Generation
GENERATOR_TYPE=mock
LTX_MODEL_PATH=Lightweight-Diffusion-Models/LTX-Video

# OpenTelemetry / Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=ltx-platform
ENABLE_OTEL=false
